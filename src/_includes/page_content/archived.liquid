{% for product in archived %}
{% assign delay_count = delay_count | plus: 50 %}
<li class="col col--1of3 card-wrapper" data-sal="slide-up" data-sal-delay="{{ delay_count }}">
  <p class="label label--secondary line-thru">
    <small class="line-thru__inner bg-white label">{{ product.label }}</small>
  </p>

  <article class="flex-col flex-space-between card">
    {% if product.img %}
      <figure class="card__media">
        <img
          src="../../assets/img/{{ product.img }}" alt="Screenshot of {{ product.name }}"
          loading="lazy"
          decoding="async"
          class="card__image"
          width="1200"
          height="675"
        >
      </figure>
    {% endif %}

    <h2 class="card__header font-serif-bold">{{ product.name }}</h2>
    <div class="card__body">
      <p>{{ product.description }}</p>
      {% comment %} <p class="no-margin">
        <a href="{{ product.url }}" target="_blank" rel="noopener">{{ product.cta }}</a>
      </p> {% endcomment %}
    </div>
  </article>
</li>
{% endfor %}
